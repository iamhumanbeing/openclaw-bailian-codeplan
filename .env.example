# ============================================
# OpenClaw Docker Configuration
# ============================================

# Alibaba Cloud Bailian API Key
# Get your API key from: https://www.aliyun.com/product/bailian
BAILIAN_API_KEY=sk-your-bailian-api-key-here

# Feishu (Lark) Bot Configuration
# Get your App ID and Secret from: https://open.feishu.cn/
FEISHU_APP_ID=cli-your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret

# Optional: Custom ports
# OPENCLAW_GATEWAY_PORT=18790
# OPENCLAW_CDP_PORT=18892
