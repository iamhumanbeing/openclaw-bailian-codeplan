# Environment variables
.env

# OpenClaw runtime data
openclaw-config/*.json
!openclaw-config/openclaw.json
openclaw-config/logs/
openclaw-config/memory/
openclaw-config/canvas/
openclaw-config/cron/
openclaw-config/devices/

# Workspace data (optional - uncomment if you don't want to commit workspace)
openclaw-workspace/*
!openclaw-workspace/.gitkeep

# Docker
.dockerignore

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
